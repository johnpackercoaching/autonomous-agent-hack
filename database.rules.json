{
  "rules": {
    "messages": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt"],
      "$messageId": {
        ".validate": "newData.hasChildren(['text', 'senderName', 'senderId', 'createdAt'])"
      }
    },
    "agents": {
      ".read": "auth != null",
      "$agentId": {
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}
